# --- GALAXY EXPRESS ERP INFRASTRUCTURE CONFIG ---

# 1. SERVER CONFIG
PORT=5000
NODE_ENV=development
JWT_SECRET=galaxy_ultra_secret_2024_billion_dollar_vision
FRONTEND_URLS=http://localhost:3000,http://localhost:3003,http://localhost:3007

# 2. DATABASE (POSTGRESQL) - Replace with your local or Railway DB URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_erp_db?schema=public"

# 3. FIREBASE / GOOGLE CLOUD
# Replace this with the actual Project ID from your Firebase console
FIREBASE_PROJECT_ID=galaxy-express-saas

# To enable FULL connectivity, place your service-account.json in this folder 
# OR paste the JSON string in the variable below (used in production)
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "..."}'

# 4. EXTERNAL SERVICES (Optional)
STRIPE_SECRET_KEY=
GOPAYFAST_MERCHANT_ID=
OPENAI_API_KEY=
