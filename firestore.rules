rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'SUPER_ADMIN';
    }
    
    function belongsToTenant(tenantId) {
      return isAuthenticated() && (getUserData().tenantId == tenantId || isSuperAdmin());
    }

    // --- COLLECTION RULES ---

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile. Super Admins can manage all.
      allow read, write: if request.auth.uid == userId || isSuperAdmin();
    }

    // Tenants collection
    match /tenants/{tenantId} {
      // Super Admins manage tenants. Tenants can read their own config.
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Orders collection (Multi-tenant)
    match /orders/{orderId} {
      // Users can read/write orders if they belong to the same tenant
      allow read: if belongsToTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && belongsToTenant(request.resource.data.tenantId);
      allow update, delete: if belongsToTenant(resource.data.tenantId);
    }

    // Stats and Global Config
    match /stats/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Generic match for other collections (scoped by tenantId)
    match /{collectionName}/{docId} {
      allow read: if isAuthenticated() && (
        !('tenantId' in resource.data) || belongsToTenant(resource.data.tenantId)
      );
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        (request.resource.data.tenantId != null && belongsToTenant(request.resource.data.tenantId))
      );
    }
  }
}
